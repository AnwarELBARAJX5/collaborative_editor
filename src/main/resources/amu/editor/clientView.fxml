<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="TOP_CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="amu.editor.ClientController">

<fx:define>
    <ContextMenu fx:id="listViewContextMenu">
        <items>
            <MenuItem text="Add Line" onAction="#handleAddLine"/>
            <MenuItem text="Delete Line" fx:id="deleteLineMenuItem" onAction="#handleDeleteLine" disable="true"/>
        </items>
    </ContextMenu>
</fx:define>

<ListView fx:id="listView" prefWidth="500" prefHeight="5000"
          contextMenu="$listViewContextMenu">
</ListView>

<TextField fx:id="textField" promptText="Select a line and  edit here..." onAction="#handleTextFieldUpdate"/>
<Button fx:id="refreshButton" text="refresh" onAction="#handleRefresh"/> <Button fx:id="cration" text="niewfile" onAction="#handleNewFile"/> <Button fx:id="sendit" text="send" onAction="#handlesendFile"/>
</VBox>
